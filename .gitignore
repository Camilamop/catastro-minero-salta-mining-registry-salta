# ============================================================
# .gitignore — catastro-minero-salta-mining-registry-salta
# ============================================================

# --- Datos geoespaciales originales (descargar desde fuente oficial) ---
data/raw/*.shp
data/raw/*.dbf
data/raw/*.shx
data/raw/*.prj
data/raw/*.cpg
data/raw/*.qix
data/raw/*.geojson
data/raw/*.gpkg
data/raw/*.zip
data/raw/*.csv

# Si querés versionar los datos procesados pero no los originales,
# descomentá la siguiente línea:
# !data/processed/

# --- Archivos grandes ---
*.tif
*.tiff
*.parquet

# --- Jupyter Notebook ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# --- Entornos virtuales ---
.env
.venv
venv/
env/

# --- Credenciales y configuración local ---
.env.local
config_local.py
secrets.py
*.key

# --- Base de datos local ---
*.db
*.sqlite
*.sqlite3

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.suo
*.user

# --- Logs ---
*.log
